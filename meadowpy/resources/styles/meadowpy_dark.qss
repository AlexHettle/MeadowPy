/* MeadowPy IDE - Dark Theme Stylesheet */

* {
    font-family: "Segoe UI", "Arial", sans-serif;
}

QMainWindow {
    background-color: #1E1E1E;
}

QMainWindow::separator {
    width: 3px;
    height: 3px;
    background: #1E1E1E;
}

/* Tab Widget — Editor Tabs */
QTabWidget {
    border: none;
}

QTabWidget::pane {
    border: none;
    background: #1E1E1E;
    margin: 0;
    padding: 0;
    margin-top: -1px;
}

QTabBar {
    background: #2D2D2D;
    qproperty-drawBase: 0;
}

QTabBar::scroller {
    width: 0px;
}

QTabBar::tear {
    width: 0px;
    image: none;
}

QTabBar QToolButton {
    background: #2D2D2D;
    border: none;
    width: 0px;
    height: 0px;
    padding: 0px;
    margin: 0px;
}

QTabBar QToolButton::left-arrow {
    image: none;
}

QTabBar QToolButton::right-arrow {
    image: none;
}

QTabBar::tab {
    background: #252525;
    border: none;
    border-left: 2px solid transparent;
    border-right: 1px solid #1A1A1A;
    margin-left: 1px;
    margin-right: 1px;
    padding: 8px 16px 8px 10px;
    min-width: 90px;
    color: #A0A0A0;
    font-size: 13px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
}

QTabBar::tab:selected {
    background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0,
        stop:0 #383838, stop:1 #2F7A44);
    color: #FFFFFF;
    border-left: 1px solid #2F7A44;
    border-top: 1px solid #2F7A44;
    border-right: 1px solid #2F7A44;
    border-bottom: 2px solid #2F7A44;
    padding-top: 6px;
    padding-right: 14px;
}

QTabBar::tab:hover:!selected {
    background: #222222;
    color: #FFFFFF;
}

QTabBar::tab:first:!selected {
    border-left: none;
}

/* Dock widget tabs (Problems, Output, Outline, etc.) */
QTabBar::tab:only-one {
    border-right: none;
}

QTabBar::tab:selected:only-one {
    border-right: 2px solid #2F7A44;
}


/* Toolbar */
QToolBar {
    background: #333333;
    border-bottom: 1px solid #3C3C3C;
    spacing: 4px;
    padding: 2px 4px;
}

QToolBar QToolButton {
    border: 1px solid transparent;
    border-radius: 4px;
    padding: 4px;
}

QToolBar QToolButton:hover {
    background: #454545;
    border-color: #555555;
}

QToolBar QToolButton:pressed {
    background: #505050;
}

/* Run / Stop / Debug — disable default hover/press so only the glow shows */
QToolBar QToolButton#runButton:hover,
QToolBar QToolButton#runButton:pressed,
QToolBar QToolButton#stopButton:hover,
QToolBar QToolButton#stopButton:pressed,
QToolBar QToolButton#debugButton:hover,
QToolBar QToolButton#debugButton:pressed {
    background: transparent;
    border-color: transparent;
}

/* Status Bar */
QStatusBar {
    background: #2F7A44;
    color: white;
    border-top: none;
    min-height: 24px;
}

QStatusBar QLabel {
    color: white;
    padding: 0 8px;
    font-size: 12px;
}

QStatusBar::item {
    border: none;
}

/* Menu Bar */
QMenuBar {
    background: #333333;
    border-bottom: 1px solid #3C3C3C;
    padding: 0px;
    color: #CCCCCC;
}

QMenuBar::item {
    padding: 6px 10px;
    border-radius: 0px;
    color: #CCCCCC;
}

QMenuBar::item:selected {
    background: #454545;
    color: #FFFFFF;
}

/* Menus */
QMenu {
    background: #2D2D2D;
    border: 1px solid #454545;
    border-radius: 5px;
    padding: 4px;
    color: #CCCCCC;
}

QMenu[menubarMenu="true"] {
    border-top-left-radius: 0px;
    border-top-right-radius: 0px;
}

QMenu::item {
    padding: 6px 24px 6px 12px;
    border-radius: 3px;
}

QMenu::item:selected {
    background: #094771;
    color: #FFFFFF;
}

QMenu::item:disabled {
    color: #666666;
}

QMenu::separator {
    height: 1px;
    background: #454545;
    margin: 4px 8px;
}

/* Find/Replace Bar */
#FindReplaceBar {
    background: #333333;
    border: 1px solid #454545;
    border-radius: 6px;
    padding: 4px;
}

#FindReplaceBar QLineEdit {
    border: 1px solid #555555;
    border-radius: 3px;
    padding: 4px 8px;
    background: #3C3C3C;
    color: #CCCCCC;
    font-size: 13px;
}

#FindReplaceBar QLineEdit:focus {
    border-color: #2F7A44;
}

#FindReplaceBar QPushButton {
    border: 1px solid #555555;
    border-radius: 3px;
    padding: 4px 8px;
    background: #3C3C3C;
    color: #CCCCCC;
    font-size: 12px;
}

#FindReplaceBar QPushButton:hover {
    background: #454545;
}

#FindReplaceBar QPushButton:pressed {
    background: #505050;
}

#FindReplaceBar QLabel {
    color: #CCCCCC;
}

#findToggleBtn {
    font-weight: bold;
    font-size: 11px;
}

#findToggleBtn:checked {
    background: #2F7A44;
    color: white;
    border-color: #245F35;
}

/* Scrollbars — slim, modern overlay style */
QScrollBar:vertical {
    background: #1E1E1E;
    width: 10px;
    border: none;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: #4A4A4A;
    min-height: 40px;
    border-radius: 4px;
    margin: 1px;
}

QScrollBar::handle:vertical:hover {
    background: #606060;
}

QScrollBar::handle:vertical:pressed {
    background: #707070;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
    background: none;
    border: none;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
    border: none;
}

QScrollBar:horizontal {
    background: #1E1E1E;
    height: 10px;
    border: none;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background: #4A4A4A;
    min-width: 40px;
    border-radius: 4px;
    margin: 1px;
}

QScrollBar::handle:horizontal:hover {
    background: #606060;
}

QScrollBar::handle:horizontal:pressed {
    background: #707070;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
    background: none;
    border: none;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
    border: none;
}

/* Dialogs */
QDialog {
    background: #2D2D2D;
    color: #CCCCCC;
}

#prefsCategory {
    background: #252526;
    border: 1px solid #3C3C3C;
    font-size: 13px;
    color: #CCCCCC;
    outline: none;
}

#prefsCategory::item {
    padding: 6px 10px;
    border-left: 3px solid transparent;
}

#prefsCategory::item:selected {
    background: #2A2D2E;
    color: #EEEEEE;
    border-left: 3px solid #2F7A44;
}

#prefsCategory::item:hover:!selected {
    background: #2A2D2E;
}

QDialogButtonBox QPushButton {
    min-width: 80px;
    padding: 6px 16px;
    border: 1px solid #555555;
    border-radius: 4px;
    background: #3C3C3C;
    color: #CCCCCC;
    outline: none;
}

QDialogButtonBox QPushButton:hover {
    background: #454545;
}

QDialogButtonBox QPushButton:default {
    background: #2F7A44;
    color: white;
    border-color: #245F35;
}

QDialogButtonBox QPushButton:default:hover {
    background: #245F35;
}

/* Input widgets in preferences */
QSpinBox, QComboBox, QFontComboBox {
    border: 1px solid #555555;
    border-radius: 3px;
    padding: 4px 8px;
    background: #3C3C3C;
    color: #CCCCCC;
    min-height: 24px;
}

QSpinBox:focus, QComboBox:focus, QFontComboBox:focus {
    border-color: #2F7A44;
}

QSpinBox::up-button, QSpinBox::down-button {
    background: #4A4A4A;
    border: none;
    border-left: 1px solid #555555;
    width: 20px;
}

QSpinBox::up-button {
    border-top-right-radius: 3px;
    border-bottom: 1px solid #555555;
}

QSpinBox::down-button {
    border-bottom-right-radius: 3px;
}

QSpinBox::up-button:hover, QSpinBox::down-button:hover {
    background: #5A5A5A;
}

QSpinBox::up-button:pressed, QSpinBox::down-button:pressed {
    background: #2F7A44;
}

QSpinBox::up-arrow {
    image: url({{ICONS_DIR}}/arrow_up.svg);
    width: 10px;
    height: 10px;
}

QSpinBox::down-arrow {
    image: url({{ICONS_DIR}}/arrow_down.svg);
    width: 10px;
    height: 10px;
}

QComboBox::drop-down {
    border: none;
}

QComboBox QAbstractItemView {
    background: #2D2D2D;
    border: 1px solid #454545;
    color: #CCCCCC;
    selection-background-color: #2F7A44;
    selection-color: #FFFFFF;
    outline: none;
}

QComboBox QAbstractItemView::item {
    padding: 4px 8px;
    border-left: 3px solid transparent;
    outline: none;
}

QComboBox QAbstractItemView::item:selected {
    border-left: 3px solid #2F7A44;
}

QComboBox QAbstractItemView::item:focus {
    outline: none;
    border: none;
    border-left: 3px solid transparent;
}

QComboBox QAbstractItemView::item:selected:focus {
    border-left: 3px solid #2F7A44;
}

QCheckBox {
    spacing: 8px;
    color: #CCCCCC;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #555555;
    border-radius: 3px;
    background: #3C3C3C;
}

QCheckBox::indicator:checked {
    background: #2F7A44;
    border-color: #245F35;
}

QLabel {
    color: #CCCCCC;
}

QInputDialog {
    background: #2D2D2D;
    color: #CCCCCC;
}

QInputDialog QLineEdit, QInputDialog QSpinBox {
    background: #3C3C3C;
    color: #CCCCCC;
    border: 1px solid #555555;
}

QMessageBox {
    background: #2D2D2D;
    color: #CCCCCC;
}

QMessageBox QPushButton {
    min-width: 80px;
    padding: 6px 16px;
    border: 1px solid #555555;
    border-radius: 4px;
    background: #3C3C3C;
    color: #CCCCCC;
}

QMessageBox QPushButton:hover {
    background: #454545;
}

/* ===== File Explorer Panel ===== */
#FileExplorer {
    background: #252526;
}

#explorerHeader {
    background: #2D2D2D;
    border-bottom: 1px solid #3C3C3C;
}

#explorerFolderLabel {
    color: #CCCCCC;
    font-size: 12px;
    font-weight: bold;
    padding: 0 4px;
}

#explorerEmptyLabel {
    color: #666666;
    font-size: 12px;
    padding: 20px;
}

#explorerTree {
    background: #1E1E1E;
    border: none;
    font-size: 13px;
    color: #CCCCCC;
}

#explorerTree::item {
    padding: 3px 4px;
    border-radius: 3px;
}

#explorerTree::item:selected {
    background: #094771;
    color: #FFFFFF;
}

#explorerTree::item:hover:!selected {
    background: #2A2D2E;
}

#explorerTree::branch:has-children:!has-siblings:closed,
#explorerTree::branch:closed:has-children:has-siblings {
    image: url({{ICONS_DIR}}/branch_closed.svg);
}

#explorerTree::branch:open:has-children:!has-siblings,
#explorerTree::branch:open:has-children:has-siblings {
    image: url({{ICONS_DIR}}/branch_open.svg);
}

/* Dock Widgets (title bars + tabified tabs) */
QDockWidget {
    color: #CCCCCC;
    titlebar-close-icon: none;
    titlebar-normal-icon: none;
}

QDockWidget::close-button,
QDockWidget::float-button {
    background: transparent;
    border: none;
    icon-size: 0px;
    padding: 0px;
    image: none;
}

QDockWidget::title {
    background: #2D2D2D;
    border-bottom: 1px solid #3C3C3C;
    padding: 6px;
    color: #CCCCCC;
}

/* Symbol Outline Panel */
#SymbolOutline {
    background: #252526;
    border-left: 1px solid #3C3C3C;
}

#SymbolOutline QWidget {
    background: #252526;
    color: #CCCCCC;
}

#symbolTree {
    background: #1E1E1E;
    border: none;
    font-size: 13px;
    color: #CCCCCC;
}

#symbolTree::item {
    padding: 3px 4px;
    border-radius: 3px;
}

#symbolTree::item:selected {
    background: #094771;
    color: #FFFFFF;
}

#symbolTree::item:hover:!selected {
    background: #2A2D2E;
}

/* Problems Panel */
#ProblemsPanel {
    background: #252526;
    border-top: 1px solid #3C3C3C;
}

#ProblemsPanel QWidget {
    background: #252526;
    color: #CCCCCC;
}

#problemsHeader {
    background: #2D2D2D;
    border-bottom: 1px solid #3C3C3C;
}

#problemsHeader QLabel {
    color: #CCCCCC;
}

#problemsTable {
    background: #1E1E1E;
    border: none;
    font-size: 12px;
    color: #CCCCCC;
    gridline-color: #2D2D2D;
}

#problemsTable::item:selected {
    background: #094771;
    color: #FFFFFF;
}

#problemsTable QHeaderView::section {
    background: #2D2D2D;
    color: #CCCCCC;
    border: none;
    border-bottom: 1px solid #3C3C3C;
    padding: 4px 8px;
    font-size: 11px;
    font-weight: bold;
}

/* ===== Search Panel ===== */

#SearchPanel {
    background: #252526;
    border-top: 1px solid #3C3C3C;
}

#SearchPanel QWidget {
    background: #252526;
    color: #CCCCCC;
}

#SearchPanel QLineEdit {
    background: #3C3C3C;
    color: #CCCCCC;
    border: 1px solid #555555;
    border-radius: 3px;
    padding: 4px 8px;
}

#SearchPanel QLineEdit:focus {
    border-color: #2F7A44;
}

#SearchPanel QPushButton {
    background: #3C3C3C;
    color: #CCCCCC;
    border: 1px solid #555555;
    border-radius: 3px;
    padding: 4px 12px;
}

#SearchPanel QPushButton:hover {
    background: #505050;
}

#SearchPanel QPushButton:pressed {
    background: #2F5C88;
}

#SearchPanel QCheckBox {
    color: #CCCCCC;
    spacing: 4px;
}

#searchStatusLabel {
    color: #999999;
    font-size: 11px;
}

#searchResultsTree {
    background: #1E1E1E;
    border: none;
    font-size: 13px;
    color: #CCCCCC;
}

#searchResultsTree::item {
    padding: 3px 4px;
    border-radius: 3px;
}

#searchResultsTree::item:selected {
    background: #094771;
    color: #FFFFFF;
}

#searchResultsTree::item:hover:!selected {
    background: #2A2D2E;
}

/* ===== Watch Panel ===== */

#WatchPanel {
    background: #252526;
}

#WatchPanel QWidget {
    background: #252526;
    color: #CCCCCC;
}

#WatchPanel QLineEdit {
    background: #3C3C3C;
    color: #CCCCCC;
    border: 1px solid #555555;
    border-radius: 3px;
    padding: 4px 8px;
}

#WatchPanel QLineEdit:focus {
    border-color: #2F5C88;
}

#WatchPanel QPushButton {
    background: #3C3C3C;
    color: #CCCCCC;
    border: 1px solid #555555;
    border-radius: 3px;
    padding: 4px 8px;
}

#WatchPanel QPushButton:hover {
    background: #4A4A4A;
}

#watchTable {
    background: #1E1E1E;
    border: none;
    font-size: 13px;
    color: #CCCCCC;
    gridline-color: #2D2D2D;
}

#watchTable::item:selected {
    background: #094771;
    color: #FFFFFF;
}

#watchTable QHeaderView::section {
    background: #2D2D2D;
    color: #CCCCCC;
    border: none;
    border-bottom: 1px solid #3C3C3C;
    padding: 4px 8px;
    font-size: 11px;
    font-weight: bold;
}

/* ===== Call Stack Panel ===== */

#CallStackPanel {
    background: #252526;
}

#CallStackPanel QWidget {
    background: #252526;
    color: #CCCCCC;
}

#callStackList {
    background: #1E1E1E;
    border: none;
    font-size: 13px;
    color: #CCCCCC;
}

#callStackList::item {
    padding: 3px 4px;
    border-radius: 3px;
}

#callStackList::item:selected {
    background: #094771;
    color: #FFFFFF;
}

#callStackList::item:hover:!selected {
    background: #2A2D2E;
}

#callStackList::item:alternate {
    background: #222222;
}

/* ===== Variable Inspector Panel ===== */

#VariableInspector {
    background: #252526;
}

#VariableInspector QWidget {
    background: #252526;
    color: #CCCCCC;
}

#variableTree {
    background: #1E1E1E;
    border: none;
    font-size: 13px;
    color: #CCCCCC;
}

#variableTree::item {
    padding: 3px 4px;
    border-radius: 3px;
}

#variableTree::item:selected {
    background: #094771;
    color: #FFFFFF;
}

#variableTree::item:hover:!selected {
    background: #2A2D2E;
}

#variableTree::item:alternate {
    background: #222222;
}

#variableTree QHeaderView::section {
    background: #2D2D2D;
    color: #CCCCCC;
    border: none;
    border-bottom: 1px solid #3C3C3C;
    padding: 4px 8px;
    font-size: 11px;
    font-weight: bold;
}

/* ===== Output Panel ===== */

#OutputPanel {
    background: #252526;
    border-top: 1px solid #3C3C3C;
}

#OutputPanel QWidget {
    background: #252526;
    color: #CCCCCC;
}

#outputHeader {
    background: #2D2D2D;
    border-bottom: 1px solid #3C3C3C;
}

#outputHeader QLabel {
    color: #CCCCCC;
}

#outputText {
    background: #1E1E1E;
    border: none;
    font-family: Consolas, "Courier New", monospace;
    font-size: 13px;
    color: #CCCCCC;
    padding: 4px;
}

#outputInputArea {
    background: #2D2D2D;
    border-top: 1px solid #3C3C3C;
}

#outputInputArea QLabel {
    color: #CCCCCC;
}

#replPrompt {
    color: #6A9955;
    font-weight: bold;
    font-family: Consolas, "Courier New", monospace;
    font-size: 13px;
}

#replRunBtn {
    background: #2F7A44;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    padding: 4px 12px;
    font-weight: bold;
}

#replRunBtn:hover {
    background: #245F35;
}

#outputInput {
    border: 1px solid #555555;
    border-radius: 3px;
    padding: 4px 8px;
    background: #3C3C3C;
    color: #CCCCCC;
    font-family: Consolas, "Courier New", monospace;
    font-size: 13px;
}

#outputInput:focus {
    border-color: #2F5C88;
}

#outputFixAIBtn {
    background: #2F5C88;
    color: #FFFFFF;
    border: none;
    border-radius: 3px;
    padding: 2px 10px;
    font-size: 11px;
    font-weight: bold;
}

#outputFixAIBtn:hover {
    background: #3A6FA0;
}

/* ===== Welcome Screen ===== */

#WelcomeWidget {
    background: #1E1E1E;
}

#welcomeTitle {
    color: #EEEEEE;
}

#welcomeSubtitle {
    color: #888888;
}

#welcomeSectionLabel {
    color: #CCCCCC;
}

#welcomeActionBtn {
    background: #2D2D2D;
    border: 1px solid #454545;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 13px;
    color: #CCCCCC;
}

#welcomeActionBtn:hover {
    background: #094771;
    border-color: #2F5C88;
    color: #FFFFFF;
}

#welcomeTemplateCard {
    background: #252526;
    border: 1px solid #3C3C3C;
    border-radius: 8px;
}

#welcomeTemplateCard:hover {
    background: #094771;
    border-color: #2F5C88;
}

#welcomeCardTitle {
    color: #EEEEEE;
}

#welcomeCardDesc {
    color: #888888;
}

/* ===== Example Library Dialog ===== */

#ExampleLibraryDialog {
    background: #1E1E1E;
}

/* Header banner */
#exLibHeader {
    background: #252526;
}

#exLibTitle {
    color: #E0E0E0;
}

#exLibSubtitle {
    color: #808080;
}

#exLibSep {
    background: #3C3C3C;
    border: none;
}

#exLibVSep {
    background: #3C3C3C;
    border: none;
}

/* Sidebar */
#exLibSidebar {
    background: #252526;
}

#exLibCatHeader {
    color: #808080;
    letter-spacing: 1px;
}

/* Category buttons */
#exLibCatBtn {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
}

#exLibCatBtn:hover {
    background: #2A2D2E;
}

#exLibCatBtn[selected="true"] {
    background: #37373D;
    border: 1px solid #4FC1FF;
}

#exLibCatName {
    color: #CCCCCC;
}

#exLibCatBtn[selected="true"] #exLibCatName {
    color: #4FC1FF;
}

#exLibCatCount {
    color: #666666;
}

/* Content area */
#exLibContent {
    background: #1E1E1E;
}

#exLibExamplesHeader {
    color: #E0E0E0;
}

/* Cards scroll area */
#exLibCardsScroll {
    background: transparent;
    border: none;
}

#exLibCardsWidget {
    background: transparent;
}

/* Example cards */
#exLibExCard {
    background: #2D2D2D;
    border: 1px solid #3C3C3C;
    border-radius: 8px;
    min-width: 160px;
    max-width: 200px;
}

#exLibExCard:hover {
    background: #333333;
    border-color: #555555;
}

#exLibExCard[selected="true"] {
    background: #2A3A2E;
    border: 1px solid #2F7A44;
}

#exLibExCardTitle {
    color: #E0E0E0;
}

#exLibExCard[selected="true"] #exLibExCardTitle {
    color: #6CCF80;
}

#exLibExCardDesc {
    color: #888888;
}

/* Preview area */
#exLibPreviewFrame {
    background: #1E1E1E;
}

#exLibPreviewBar {
    background: #2D2D2D;
    border: 1px solid #3C3C3C;
    border-bottom: none;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
}

#exLibPreviewTitle {
    color: #E0E0E0;
}

#exLibPreviewDesc {
    color: #888888;
}

#exLibCodePreview {
    background: #1A1A1A;
    border: 1px solid #3C3C3C;
    border-top: none;
    border-bottom-left-radius: 6px;
    border-bottom-right-radius: 6px;
    font-family: Consolas, "Courier New", monospace;
    font-size: 13px;
    color: #D4D4D4;
    padding: 8px;
}

/* Footer */
#exLibFooter {
    background: #252526;
}

#exLibCountLabel {
    color: #666666;
}

#exLibOpenBtn {
    background: #2F7A44;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 6px 18px;
    font-size: 13px;
    font-weight: bold;
}

#exLibOpenBtn:hover {
    background: #38934F;
}

#exLibOpenBtn:disabled {
    background: #3C3C3C;
    color: #666666;
}

#exLibCloseBtn {
    background: #3C3C3C;
    color: #CCCCCC;
    border: 1px solid #555555;
    border-radius: 6px;
    padding: 6px 18px;
    font-size: 13px;
}

#exLibCloseBtn:hover {
    background: #505050;
}

/* ===== Shortcut Reference Dialog v2 ===== */

#ShortcutReferenceDialog {
    background: #1E1E1E;
}

#shortcutTitle {
    color: #EEEEEE;
}

#shortcutSubtitle {
    color: #888888;
}

#shortcutSearch {
    background: #2A2D2E;
    border: 1px solid #3C3C3C;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 13px;
    color: #CCCCCC;
}

#shortcutSearch:focus {
    border-color: #2F7A44;
}

#shortcutScroll {
    background: transparent;
}

#shortcutContainer {
    background: transparent;
}

#shortcutCard {
    background: #252526;
    border: 1px solid #3C3C3C;
    border-radius: 8px;
}

#shortcutCardHeader {
    color: #EEEEEE;
    padding: 10px 14px 6px 14px;
}

#shortcutCardSep {
    background: #3C3C3C;
    margin-left: 14px;
    margin-right: 14px;
}

#shortcutRow {
    border-radius: 4px;
    margin: 1px 6px;
}

#shortcutRow:hover {
    background: #2A2D2E;
}

#shortcutActionLabel {
    color: #CCCCCC;
    font-size: 13px;
}

#shortcutKeyBadge {
    background: #3C3C3C;
    color: #DDDDDD;
    border: 1px solid #555555;
    border-bottom: 2px solid #555555;
    border-radius: 4px;
    padding: 2px 8px;
    font-family: "Consolas", monospace;
    font-size: 12px;
    min-width: 22px;
}

#shortcutKeyPlus {
    color: #666666;
    font-size: 12px;
}

#shortcutNoResults {
    color: #666666;
    font-size: 13px;
    padding: 20px;
}

#shortcutCloseBtn {
    background: #3C3C3C;
    color: #CCCCCC;
    border: 1px solid #555555;
    border-radius: 6px;
    padding: 6px 20px;
    font-size: 13px;
}

#shortcutCloseBtn:hover {
    background: #505050;
}

/* ===== Keyword Help Popup ===== */

#KeywordHelpPopup {
    background: #252526;
    border: 1px solid #555555;
    border-radius: 6px;
}

#kwHelpTitle {
    color: #4FC1FF;
}

#kwHelpDesc {
    color: #CCCCCC;
}

#kwHelpExampleLabel {
    color: #888888;
}

#kwHelpCode {
    background: #1E1E1E;
    border: 1px solid #3C3C3C;
    border-radius: 4px;
    color: #D4D4D4;
    padding: 6px;
}

/* ===== Ollama / AI Status ===== */

#ollamaStatusLabel {
    padding: 0 8px;
    font-size: 12px;
    color: white;
}

#modelSelectorMenu {
    background: #2D2D2D;
    border: 1px solid #454545;
    border-radius: 5px;
    padding: 4px;
    color: #CCCCCC;
}

#modelSelectorMenu::item {
    padding: 6px 24px 6px 12px;
    border-radius: 3px;
}

#modelSelectorMenu::item:selected {
    background: #094771;
    color: #FFFFFF;
}

#modelSelectorMenu::item:disabled {
    color: #666666;
}

#modelSelectorMenu::separator {
    height: 1px;
    background: #454545;
    margin: 4px 8px;
}

/* ===== AI Chat Panel ===== */

#aiChatHeader {
    background: #252525;
    border-bottom: 1px solid #3C3C3C;
}

#aiChatModelLabel {
    font-weight: bold;
    color: #CCCCCC;
    font-size: 12px;
}

#aiChatClearBtn {
    background: transparent;
    border: 1px solid #555555;
    border-radius: 4px;
    padding: 2px 10px;
    color: #AAAAAA;
    font-size: 11px;
}

#aiChatClearBtn:hover {
    background: #3C3C3C;
    border-color: #666666;
}

#aiChatDisplay {
    background: #1E1E1E;
    border: none;
    border-bottom: 1px solid #3C3C3C;
    font-size: 13px;
    color: #D4D4D4;
}

#aiChatInputContainer {
    background: #252525;
    border-top: 1px solid #3C3C3C;
}

#aiChatInput {
    background: #2D2D2D;
    border: 1px solid #3C3C3C;
    border-radius: 6px;
    padding: 6px 8px;
    font-size: 13px;
    color: #D4D4D4;
}

#aiChatInput:focus {
    border-color: #007ACC;
}

#aiChatSendBtn {
    background: #2F7A44;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    font-weight: bold;
    font-size: 13px;
}

#aiChatSendBtn:hover {
    background: #245F35;
}

#aiChatSendBtn:disabled {
    background: #555555;
    color: #888888;
}
